# ===== Database =====
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/forktracker
DATABASE_URL_ASYNC=postgresql+asyncpg://postgres:postgres@localhost:5432/forktracker

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== Secrets =====
SECRET_KEY=change-this-in-production-32-bytes-min
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=10080
ENCRYPTION_KEY=

# ===== Supabase =====
SUPABASE_URL=
SUPABASE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ===== GitHub =====
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ===== AI Providers =====
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# ===== Notifications =====
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@forktracker.app
TELEGRAM_BOT_TOKEN=

# ===== CORS =====
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://app.forktracker.com"]

# ===== App =====
MAX_FORKS_PER_USER=500
SYNC_INTERVAL_HOURS=6
LOG_LEVEL=INFO
SENTRY_DSN=

# ===== Storage (S3) =====
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=forktracker-assets
S3_REGION=us-east-1

# ===== Monitoring =====
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
